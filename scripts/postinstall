#!/bin/bash
# Set permissions and load the LaunchAgent for the currently logged-in user.

# Ensure scripts are executable
chmod +x /Library/Scripts/DriveMapping/map_drives.sh
chmod +x /Library/Scripts/DriveMapping/uninstall.sh
[[ -f /Library/Scripts/DriveMapping/mount_helper ]] && chmod +x /Library/Scripts/DriveMapping/mount_helper

CURRENT_USER=$(stat -f "%Su" /dev/console)
USER_ID=$(id -u "$CURRENT_USER" 2>/dev/null) || true

if [[ -n "$CURRENT_USER" && "$CURRENT_USER" != "root" && -n "$USER_ID" ]]; then
    launchctl bootstrap "gui/$USER_ID" /Library/LaunchAgents/com.drivemapping.plist 2>/dev/null || true
fi

exit 0
